  "keyFeatures": [
    "Serial and IP150 module connections to Paradox alarm panels",
    "MQTT integration with full topic hierarchy for zones, partitions, outputs, and events",
    "Home Assistant auto-discovery via MQTT",
    "Push notifications via Pushbullet, Pushover, Signal, and GSM/SMS",
    "Supports MG/SP/EVO panel families (Magellan, Spectra, EVO)",
    "Docker multi-arch images (386, amd64, armv6, armv7, arm64)",
    "Event filtering with tag-based or regexp rules",
    "Configuration via .conf, .json, or .yaml files with environment variable overrides",
    "Panel time synchronization",
    "IP150 SITE ID (SWAN) cloud connection support"
  ],
  "publicApiSurface": [
    "pai-service CLI command",
    "pai-dump-memory CLI command",
    "ip150-connection-decrypt CLI command",
    "MQTT topic: paradox/zones/{name}/states/{property}",
    "MQTT topic: paradox/partitions/{name}/states/{property}",
    "MQTT topic: paradox/control/{type}/{name}/{command}",
    "MQTT topic: paradox/events/raw",
    "MQTT topic: paradox/interface/pai_status",
    "Config: CONNECTION_TYPE (Serial|IP)",
    "Config: MQTT_ENABLE, MQTT_HOST, MQTT_PORT",
    "Config: MQTT_HOMEASSISTANT_AUTODISCOVERY_ENABLE",
    "Config: PUSHBULLET_ENABLE, PUSHOVER_ENABLE, SIGNAL_ENABLE, GSM_ENABLE"
  ]
